# Core platform
AIRFLOW_FERNET_KEY=replace-with-a-real-fernet-key
AIRFLOW_API_SECRET_KEY=replace-with-a-random-api-secret-key
AIRFLOW_JWT_SECRET=replace-with-a-random-jwt-secret
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=change-me
KAFKA_EXTERNAL_HOST=localhost

# MQTT / VerneMQ
VERNEMQ_DISTRIBUTED_COOKIE=replace-with-a-long-random-cookie
VERNEMQ_ADMIN_PASSWORD=change-me

# MinIO application credentials used by Airflow/Flink/Beam
MINIO_APP_ACCESS_KEY=change-me
MINIO_APP_SECRET_KEY=change-me-secret
ACME_EMAIL=admin@example.com
STORAGE_BASE_DOMAIN=example.com

# Public URLs used by browser-facing UIs
APICURIO_PUBLIC_URL=http://localhost:8082
GRAFANA_PUBLIC_URL=http://localhost:3000
PGADMIN_DEFAULT_EMAIL=admin@example.com
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me

# Build pins
BEAM_GIT_REF=f2aa79124012a3324f0813cc80f8e99dfb7546bb
FLINK_JOBSERVER_GRADLE_TASK=:runners:flink:2.0:job-server:shadowJar
