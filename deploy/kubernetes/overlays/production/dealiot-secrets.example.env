MQTT_PASSWORD=replace-with-production-mqtt-password
AWS_ACCESS_KEY_ID=replace-with-production-s3-access-key
AWS_SECRET_ACCESS_KEY=replace-with-production-s3-secret-key
AIRFLOW__CORE__FERNET_KEY=replace-with-production-fernet-key
AIRFLOW__API__SECRET_KEY=replace-with-production-airflow-api-secret
AIRFLOW__API_AUTH__JWT_SECRET=replace-with-production-airflow-jwt-secret
AIRFLOW_ADMIN_PASSWORD=replace-with-production-airflow-admin-password
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=postgresql+psycopg://airflow:replace-me@postgres.example.net:5432/airflow?sslmode=require
AIRFLOW__CELERY__RESULT_BACKEND=db+postgresql://airflow:replace-me@postgres.example.net:5432/airflow?sslmode=require
AIRFLOW__CELERY__BROKER_URL=rediss://redis.example.net:6379/0
