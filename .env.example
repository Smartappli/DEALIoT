# Core platform
AIRFLOW_FERNET_KEY=<generate-with-airflow-fernet>
AIRFLOW_API_SECRET_KEY=<generate-random-value>
AIRFLOW_JWT_SECRET=<generate-random-value>
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=<generate-random-value>
AIRFLOW_DB_PASSWORD=<generate-random-value>
KAFKA_EXTERNAL_HOST=localhost

# MQTT / VerneMQ
VERNEMQ_DISTRIBUTED_COOKIE=<generate-random-value>
VERNEMQ_ADMIN_PASSWORD=<generate-random-value>
MQTT_TOPICS=$share/ingestors/devices/#,$share/ingestors/wildfi/#
WILDFI_DECODER_REPOSITORY=https://github.com/wildlab/WildFiDecoder
WILDFI_FIRMWARE_REPOSITORY=https://github.com/trichl/WildFiOpenSource
WILDFI_TOPIC_PREFIXES=wildfi,wild-fi

# SeaweedFS S3 credentials used by Airflow/Flink/Beam
SEAWEEDFS_S3_ACCESS_KEY=<generate-random-value>
SEAWEEDFS_S3_SECRET_KEY=<generate-random-value>
ACME_EMAIL=admin@example.com
STORAGE_BASE_DOMAIN=example.com

# Public URLs used by browser-facing UIs
APICURIO_PUBLIC_URL=http://localhost:8082
GRAFANA_PUBLIC_URL=http://localhost:3000
PGADMIN_DEFAULT_EMAIL=admin@example.com
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=<generate-random-value>

# Build pins
BEAM_GIT_REF=f2aa79124012a3324f0813cc80f8e99dfb7546bb
FLINK_JOBSERVER_GRADLE_TASK=:runners:flink:2.0:job-server:shadowJar
